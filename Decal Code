<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Your Decal Code</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blush:    #F7E1EA;
      --lavender: #EAE3F5;
      --cream:    #FDFAF6;
      --rose:     #D4678A;
      --soft-rose:#E8A0B8;
      --plum:     #3D2440;
      --muted:    #8C7A8E;
      --radius:   16px;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: linear-gradient(145deg, #F2D9E6 0%, #EAE3F5 100%);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .card {
      background: #fff;
      border-radius: 24px;
      padding: 44px 36px 40px;
      max-width: 380px;
      width: 100%;
      text-align: center;
      box-shadow: 0 8px 40px rgba(61,36,64,0.10);
    }

    .icon {
      font-size: 40px;
      margin-bottom: 16px;
      display: block;
    }

    .eyebrow {
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--rose);
      font-weight: 600;
      margin-bottom: 8px;
    }

    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 26px;
      font-weight: 600;
      color: var(--plum);
      margin-bottom: 6px;
      line-height: 1.2;
    }

    .subtitle {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 32px;
      line-height: 1.6;
    }

    /* ── CODE BOX ── */
    .code-box {
      background: var(--blush);
      border: 1.5px solid #EDD8E8;
      border-radius: var(--radius);
      padding: 18px 20px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .code-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
      font-weight: 600;
      text-align: left;
      white-space: nowrap;
    }

    .code-value {
      font-size: 18px;
      font-weight: 600;
      color: var(--plum);
      letter-spacing: 0.06em;
      font-variant-numeric: tabular-nums;
    }

    /* ── COPY BUTTON ── */
    .copy-btn {
      width: 100%;
      padding: 15px;
      background: var(--rose);
      color: #fff;
      border: none;
      border-radius: var(--radius);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      letter-spacing: 0.04em;
      transition: background 0.15s, transform 0.1s;
    }

    .copy-btn:hover { background: #BF5577; }
    .copy-btn:active { transform: scale(0.98); }

    .copy-btn.copied {
      background: #4CAF81;
    }

    /* ── INSTRUCTIONS ── */
    .instructions {
      margin-top: 28px;
      background: var(--lavender);
      border-radius: var(--radius);
      padding: 16px 18px;
      text-align: left;
    }

    .instructions p {
      font-size: 11px;
      color: var(--muted);
      line-height: 1.8;
      font-weight: 400;
    }

    .instructions strong {
      color: var(--plum);
      font-weight: 600;
    }

    /* ── TOAST ── */
    #toast {
      position: fixed;
      bottom: 28px;
      left: 50%;
      transform: translateX(-50%) translateY(20px);
      background: var(--plum);
      color: #fff;
      font-size: 13px;
      font-weight: 500;
      padding: 10px 22px;
      border-radius: 100px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease, transform 0.2s ease;
      white-space: nowrap;
      z-index: 999;
    }

    #toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    footer {
      margin-top: 20px;
      font-size: 11px;
      color: rgba(61,36,64,0.4);
      letter-spacing: 0.04em;
    }
  </style>
</head>
<body>

  <div class="card">
    <span class="icon">🌿</span>
    <p class="eyebrow">Your Purchase</p>

    <!-- CHANGE THIS: decal name -->
    <h1>Monstera Leaf</h1>
    <p class="subtitle">Copy the decal ID below and paste it into Bloxburg's decal field.</p>

    <div class="code-box">
      <div>
        <p class="code-label">Decal ID</p>
        <!-- CHANGE THIS: the actual decal ID -->
        <p class="code-value" id="decal-id">000000000</p>
      </div>
    </div>

    <button class="copy-btn" onclick="copyID()">Copy ID</button>

    <div class="instructions">
      <p>
        <strong>How to use:</strong><br/>
        1. Copy the ID above<br/>
        2. Open Bloxburg → Build Mode<br/>
        3. Select Decals → paste the ID<br/>
        4. Place on any surface ✓
      </p>
    </div>
  </div>

  <footer>© your store name · do not share this link</footer>

  <div id="toast">Copied ✓</div>

  <script>
    function copyID() {
      const id = document.getElementById('decal-id').textContent;
      const btn = document.querySelector('.copy-btn');

      navigator.clipboard.writeText(id).then(() => {
        btn.textContent = 'Copied ✓';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = 'Copy ID';
          btn.classList.remove('copied');
        }, 2000);

        const toast = document.getElementById('toast');
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2200);
      });
    }
  </script>

</body>
</html>
